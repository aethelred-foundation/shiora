# Aethelred RPC endpoint
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.aethelred.org

# Shiora Health AI API
NEXT_PUBLIC_SHIORA_API_URL=https://api.shiora.health

# IPFS Gateway
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.ipfs.io/ipfs/

# Signed session secret for wallet-backed API auth (32+ chars required in production)
SHIORA_SESSION_SECRET=replace-with-a-long-random-secret-before-production

# Comma-separated browser origins allowed to call the API
SHIORA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://shiora.health,https://app.shiora.health

# Session lifetime for signed auth cookies
SHIORA_SESSION_TTL_HOURS=24

# Leave false until HTTPS and domain setup are fully validated in production
SHIORA_ENABLE_HSTS=false

# For local development only. Keep false in production.
SHIORA_ALLOW_INSECURE_WALLET_HEADER=false
