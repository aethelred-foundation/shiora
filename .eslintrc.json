{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "react/no-unescaped-entities": "off",
    "react-hooks/exhaustive-deps": "warn",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["warn", "multi-line"]
  },
  "overrides": [
    {
      "files": ["**/__tests__/**/*", "**/*.test.*", "jest.setup.js"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
